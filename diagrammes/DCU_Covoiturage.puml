@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Visiteur" as Visiteur
actor "Utilisateur" as Utilisateur
actor "Passager" as Passager
actor "Conducteur" as Conducteur
actor "Administrateur" as Admin

Utilisateur <|-- Passager
Utilisateur <|-- Conducteur
Utilisateur <|-- Admin

rectangle "Système de Covoiturage Universitaire" {

  usecase "S'inscrire" as UC1
  usecase "Se connecter" as UC2

  usecase "Rechercher un trajet" as UC3
  usecase "Consulter les résultats" as UC4

  usecase "Réserver un trajet" as UC5
  usecase "Annuler une réservation" as UC6
  usecase "Consulter mes réservations" as UC7

  usecase "Gérer profil conducteur" as UC8
  usecase "Proposer un trajet" as UC9
  usecase "Consulter les réservations reçues" as UC10

  usecase "Gérer les utilisateurs" as UC11
  usecase "Gérer les trajets" as UC12
  usecase "Consulter le tableau de bord" as UC13

  usecase "Envoyer une notification" as UC14
}

Visiteur --> UC1
Visiteur --> UC3
Visiteur --> UC4

Utilisateur --> UC2

Passager --> UC3
Passager --> UC4
Passager --> UC5
Passager --> UC6
Passager --> UC7

Conducteur --> UC8
Conducteur --> UC9
Conducteur --> UC10

Admin --> UC11
Admin --> UC12
Admin --> UC13

UC5 ..> UC2 : <<include>>
UC6 ..> UC2 : <<include>>
UC7 ..> UC2 : <<include>>
UC8 ..> UC2 : <<include>>
UC9 ..> UC2 : <<include>>
UC10 ..> UC2 : <<include>>
UC11 ..> UC2 : <<include>>
UC12 ..> UC2 : <<include>>
UC13 ..> UC2 : <<include>>

UC4 ..> UC3 : <<extend>>
UC14 ..> UC5 : <<extend>>
UC14 ..> UC6 : <<extend>>
UC14 ..> UC9 : <<extend>>

@enduml
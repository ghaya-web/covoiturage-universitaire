@startuml
title Diagramme de Séquence - Réservation d'un trajet

actor Passager
participant "Recherche" as Recherche
participant "Trajet" as Trajet
participant "Reservation" as Reservation

Passager -> Recherche : saisirCritères(depart, destination, date)
activate Recherche

Recherche -> Trajet : rechercherTrajet(depart, destination, date)
activate Trajet
Trajet --> Recherche : listeTrajetsDisponibles
deactivate Trajet

Recherche --> Passager : afficherRésultats(listeTrajetsDisponibles)
deactivate Recherche

Passager -> Reservation : reserverTrajet(idTrajet)
activate Reservation

Reservation -> Trajet : verifierPlacesDisponibles()
activate Trajet
Trajet --> Reservation : placesDisponibles
deactivate Trajet

alt places disponibles
    Reservation -> Reservation : confirmerReservation()
    Reservation -> Trajet : diminuerPlaces()
    activate Trajet
    Trajet --> Reservation : placesMisesAJour
    deactivate Trajet
    Reservation --> Passager : réservation confirmée
else pas de places disponibles
    Reservation --> Passager : réservation refusée
end

deactivate Reservation
@enduml